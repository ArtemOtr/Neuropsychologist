# Application
APP_NAME=neuropsychologist-agent
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# OpenAI-compatible LLM API
# Example: https://api.openai.com/v1 or http://localhost:4000/v1
LLM_BASE_URL=http://localhost:4000/v1
LLM_API_KEY=change-me

# Default model for chat completions
LLM_MODEL=openai/gpt-4o-mini

# Request defaults
LLM_TIMEOUT=60.0
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=5000

# Langfuse tracing
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=change-me
LANGFUSE_SECRET_KEY=change-me
LANGFUSE_TIMEOUT=15
LANGFUSE_PROMPT_LABEL=production
LANGFUSE_REWRITE_PROMPT_NAME=rewrite_query
LANGFUSE_ANSWER_PROMPT_NAME=answer_with_rag

# Qdrant hybrid search
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT=30.0
QDRANT_COLLECTION=khors_books
QDRANT_COLLECTIONS=khors_books,youtube_videos,telegram_posts
QDRANT_TOP_K=5
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
QDRANT_FUSION=rrf

# OpenAI-compatible dense embeddings API.
# EMBEDDING_BASE_URL and EMBEDDING_API_KEY default to LLM_BASE_URL/LLM_API_KEY.
EMBEDDING_BASE_URL=http://localhost:4000/v1
EMBEDDING_API_KEY=change-me
EMBEDDING_MODEL=bge-m3
EMBEDDING_TIMEOUT=30.0

# Sparse embeddings / BM25
SPARSE_EMBEDDING_MODEL_NAME=Qdrant/bm25
SPARSE_EMBEDDING_LOCAL_FILES_ONLY=false

# Reranker
RERANKER_API_BASE=http://localhost:8001
RERANKER_API_KEY=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TIMEOUT=30.0
RERANKER_TOP_N=3
RERANKER_MIN_SCORE=0.0
RERANKER_VERIFY=true
